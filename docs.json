{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Xpdite",
  "colors": {
    "primary": "#F59E0B",
    "light": "#FBBF24",
    "dark": "#B45309"
  },
  "favicon": "/logo/xpdite-logo-transparent.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Product",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart",
              "features/overview"
            ]
          },
          {
            "group": "Core workflows",
            "pages": [
              "features/chat-and-tabs",
              "features/models-and-providers",
              "features/skills",
              "features/terminal",
              "features/memory"
            ]
          },
          {
            "group": "Power features",
            "pages": [
              "features/artifacts",
              "features/scheduled-jobs",
              "features/meeting-recorder",
              "features/notifications"
            ]
          },
          {
            "group": "Integrations",
            "pages": [
              "integrations/marketplace",
              "integrations/mcp-guide",
              "integrations/mobile-bridge"
            ]
          },
          {
            "group": "Operate safely",
            "pages": [
              "reference/operations",
              "reference/security",
              "reference/troubleshooting"
            ]
          }
        ]
      },
      {
        "tab": "Reference",
        "groups": [
          {
            "group": "Architecture and config",
            "pages": [
              "reference/architecture",
              "reference/configuration",
              "reference/api-reference"
            ]
          },
          {
            "group": "Build and contribute",
            "pages": [
              "development",
              "reference/contributing"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/KashyapTan/Xpdite",
          "icon": "github"
        },
        {
          "anchor": "Releases",
          "href": "https://github.com/KashyapTan/Xpdite/releases",
          "icon": "download"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/xpdite-logo-transparent.svg",
    "dark": "/logo/xpdite-logo-black-bg.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/KashyapTan/Xpdite"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Download",
      "href": "https://github.com/KashyapTan/Xpdite/releases"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/KashyapTan/Xpdite"
    }
  }
}
